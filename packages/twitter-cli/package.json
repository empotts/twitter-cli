{
  "name": "twitter-cli-ts",
  "version": "0.1.0",
  "description": "Thin TypeScript CLI wrapper for twitter-cli-ts core",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "twitter-ts": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
